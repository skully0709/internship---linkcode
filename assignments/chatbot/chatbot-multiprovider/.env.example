# Copy this file to .env and fill in the keys you have.
# You only need ONE of these to run the app — but adding more gives you
# automatic fallback when one provider is rate-limited or down.

# 1) Gemini — required for voice input (native audio understanding).
#    Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# 2) Groq — free, very fast, good first fallback for text chat.
#    Free key: https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# 3) OpenRouter — free tier with community-hosted models, final fallback.
#    Free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here
