# Copy this file to .env and fill in your own values.
# .env is git-ignored, so your real credentials never get committed.
#
# For Gmail: use a 16-character App Password, not your normal account
# password - generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account).

SENDER_EMAIL=
SENDER_PASSWORD=
