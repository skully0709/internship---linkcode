DROP TABLE IF EXISTS Adoption_History;
DROP TABLE IF EXISTS Vaccinations;
DROP TABLE IF EXISTS Pets;
DROP TABLE IF EXISTS Adopters;
DROP TABLE IF EXISTS Shelters;

CREATE TABLE Shelters (
    Shelter_ID INTEGER PRIMARY KEY AUTOINCREMENT,
    Shelter_Name VARCHAR(100) NOT NULL,
    Location VARCHAR(255) NOT NULL,
    Contact_Number VARCHAR(20),
    Capacity INT
);

CREATE TABLE Adopters (
    Adopter_ID INTEGER PRIMARY KEY AUTOINCREMENT,
    Name VARCHAR(100) NOT NULL,
    Phone VARCHAR(20) NOT NULL,
    Email VARCHAR(100) UNIQUE,
    Address TEXT,
    Occupation VARCHAR(100)
);

CREATE TABLE Pets (
    Pet_ID INTEGER PRIMARY KEY AUTOINCREMENT,
    Name VARCHAR(50) NOT NULL,
    Species VARCHAR(50) NOT NULL,
    Breed VARCHAR(50),
    Age INT,
    Gender VARCHAR(10),
    Health_Status VARCHAR(100),
    Adoption_Status VARCHAR(50) DEFAULT 'Available',
    Shelter_ID INT,
    FOREIGN KEY (Shelter_ID) REFERENCES Shelters(Shelter_ID) ON DELETE SET NULL
);

CREATE TABLE Vaccinations (
    Vaccination_ID INTEGER PRIMARY KEY AUTOINCREMENT,
    Pet_ID INT NOT NULL,
    Vaccine_Name VARCHAR(100) NOT NULL,
    Vaccination_Date DATE NOT NULL,
    Next_Due_Date DATE,
    Veterinarian VARCHAR(100),
    FOREIGN KEY (Pet_ID) REFERENCES Pets(Pet_ID) ON DELETE CASCADE
);

CREATE TABLE Adoption_History (
    Adoption_ID INTEGER PRIMARY KEY AUTOINCREMENT,
    Pet_ID INT NOT NULL,
    Adopter_ID INT NOT NULL,
    Adoption_Date DATE NOT NULL,
    Return_Date DATE,
    Adoption_Status VARCHAR(50) NOT NULL,
    FOREIGN KEY (Pet_ID) REFERENCES Pets(Pet_ID) ON DELETE RESTRICT,
    FOREIGN KEY (Adopter_ID) REFERENCES Adopters(Adopter_ID) ON DELETE RESTRICT
);

